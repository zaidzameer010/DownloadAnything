{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "DownloadAnything",
  "version": "0.1.0",
  "identifier": "com.DownloadAnything.dev",
  "build": {
    "frontendDist": "../dist-frontend",
    "beforeDevCommand": "node build-backend.js",
    "beforeBuildCommand": "node build-backend.js"
  },
  "app": {
    "windows": [
      {
        "title": "DownloadAnything",
        "width": 1920,
        "height": 1080,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' https://unpkg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' http://127.0.0.1:8000 ws://127.0.0.1:8000; img-src 'self' data:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/main"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "${env:TAURI_SIGNING_PUBLIC_KEY}",
      "endpoints": [
        "https://github.com/zaidzameer010/DownloadAnything/releases/latest/download/latest.json"
      ]
    }
  }
}
