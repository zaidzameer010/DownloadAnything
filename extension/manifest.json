{
  "manifest_version": 3,
  "name": "Stream Snatcher — Enterprise Media Acquisition",
  "version": "1.0.0",
  "description": "Silently sniff HLS/DASH/MP4 streams, overlay download buttons, and route to the local FastAPI acquisition engine.",
  "minimum_chrome_version": "114",
  "permissions": [
    "activeTab",
    "contextMenus",
    "downloads",
    "scripting",
    "storage",
    "tabs",
    "webRequest"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_title": "Stream Snatcher"
  }
}